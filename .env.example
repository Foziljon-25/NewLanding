# Backend base URL. The frontend app appends /calculator automatically
# unless this value already ends with /calculator.
NEXT_PUBLIC_CALCULATOR_API_BASE_URL=https://crm-api.procare.uz/

# Landing request form backend base URL. Falls back to
# NEXT_PUBLIC_CALCULATOR_API_BASE_URL when omitted. The frontend app appends
# /repair-orders/open unless this value already ends with that path.
NEXT_PUBLIC_PROCARE_REQUEST_API_URL=https://crm-api.procare.uz/
